<UserControl x:Class="POS.Views.ModernDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:POS.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/EnhancedControls.xaml"/>
                <ResourceDictionary Source="/Styles/Animations.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:CurrencyConverter x:Key="CurrencyConverter"/>
            <converters:DateTimeConverter x:Key="DateTimeConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Modern Header with Gradient -->
        <Border Grid.Row="0"
                Background="{StaticResource OrangeGradient}"
                Padding="40,30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Greeting Section -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding GreetingMessage}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Margin="0,8,0,0">
                        <Run Text="{Binding CurrentDate, StringFormat='dddd, MMMM dd, yyyy'}" Foreground="White" Opacity="0.9" FontSize="14"/>
                        <Run Text=" • " Foreground="White" Opacity="0.7"/>
                        <Run Text="{Binding CurrentUserRole}" Foreground="White" Opacity="0.9" FontSize="14"/>
                    </TextBlock>
                </StackPanel>

                <!-- Quick Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄"
                            Style="{StaticResource IconButton}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh Dashboard"
                            Margin="0,0,10,0"
                            Foreground="White"
                            FontSize="18"/>
                    <Button Content="⚙️"
                            Style="{StaticResource IconButton}"
                            Command="{Binding ViewSettingsCommand}"
                            ToolTip="Settings"
                            Foreground="White"
                            FontSize="18"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,30">

                <!-- Today's Performance Cards -->
                <TextBlock Text="Today's Performance"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,20"/>

                <UniformGrid Rows="1" Columns="4" Margin="0,0,0,30">
                    <!-- Sales Card -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,15,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="💰" FontSize="32" HorizontalAlignment="Left"/>
                                <Border Background="{DynamicResource SuccessBrush}"
                                        CornerRadius="12"
                                        Padding="8,4"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="+12%" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Total Sales"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding TodaySales, Converter={StaticResource CurrencyConverter}}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Transactions Card -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,15,0">
                        <StackPanel>
                            <TextBlock Text="🧾" FontSize="32" HorizontalAlignment="Left"/>
                            <TextBlock Text="Transactions"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding TodayTransactions}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="Avg:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <Run Text="{Binding TodayAverage, Converter={StaticResource CurrencyConverter}}"
                                     Foreground="{DynamicResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Customers Card -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,15,0">
                        <StackPanel>
                            <TextBlock Text="👥" FontSize="32" HorizontalAlignment="Left"/>
                            <TextBlock Text="Customers Served"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding TodayCustomers}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick Start Card -->
                    <Border Style="{StaticResource StatCard}"
                            Background="{StaticResource OrangeGradient}"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding Command="{Binding StartNewSaleCommand}" MouseAction="LeftClick"/>
                        </Border.InputBindings>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="➕" FontSize="40" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Start New Sale"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Week & Month Overview -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- This Week -->
                    <Border Grid.Column="0" Style="{StaticResource AnimatedCard}">
                        <StackPanel>
                            <TextBlock Text="📊 This Week"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Sales"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding WeekSales, Converter={StaticResource CurrencyConverter}}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource SuccessBrush}"
                                        CornerRadius="12"
                                        Padding="10,6"
                                        VerticalAlignment="Center">
                                    <TextBlock Foreground="White" FontWeight="SemiBold">
                                        <Run Text="↑"/>
                                        <Run Text="{Binding WeekGrowth, StringFormat='{}{0:F1}%'}"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Separator Style="{StaticResource Divider}"/>
                            <Grid>
                                <TextBlock Text="Transactions" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding WeekTransactions}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- This Month -->
                    <Border Grid.Column="2" Style="{StaticResource AnimatedCard}">
                        <StackPanel>
                            <TextBlock Text="📈 This Month"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Sales"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding MonthSales, Converter={StaticResource CurrencyConverter}}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource SuccessBrush}"
                                        CornerRadius="12"
                                        Padding="10,6"
                                        VerticalAlignment="Center">
                                    <TextBlock Foreground="White" FontWeight="SemiBold">
                                        <Run Text="↑"/>
                                        <Run Text="{Binding MonthGrowth, StringFormat='{}{0:F1}%'}"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Separator Style="{StaticResource Divider}"/>
                            <Grid>
                                <TextBlock Text="Transactions" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding MonthTransactions}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quick Actions Grid -->
                <TextBlock Text="Quick Actions"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,20"/>

                <UniformGrid Rows="2" Columns="3" Margin="0,0,0,30">
                    <!-- Inventory Button -->
                    <Button Style="{StaticResource QuickActionButton}" Margin="0,0,15,15"
                            Command="{Binding ManageInventoryCommand}">
                        <StackPanel>
                            <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Inventory"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock Text="{Binding TotalProducts, StringFormat='{}{0} products'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Customers Button -->
                    <Button Style="{StaticResource QuickActionButton}" Margin="0,0,15,15"
                            Command="{Binding ManageCustomersCommand}">
                        <StackPanel>
                            <TextBlock Text="👥" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Customers"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock Text="{Binding TotalCustomers, StringFormat='{}{0} customers'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Employees Button -->
                    <Button Style="{StaticResource QuickActionButton}" Margin="0,0,0,15"
                            Command="{Binding ManageEmployeesCommand}">
                        <StackPanel>
                            <TextBlock Text="👔" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Employees"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock Text="{Binding ActiveEmployees, StringFormat='{}{0} active'}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Reports Button -->
                    <Button Style="{StaticResource QuickActionButton}" Margin="0,0,15,0"
                            Command="{Binding ViewReportsCommand}">
                        <StackPanel>
                            <TextBlock Text="📊" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reports"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock Text="View Analytics"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Inventory Alerts -->
                    <Button Style="{StaticResource QuickActionButton}" Margin="0,0,15,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="⚠️" FontSize="36" HorizontalAlignment="Center"/>
                                <Border Background="{DynamicResource ErrorBrush}"
                                        CornerRadius="12"
                                        Padding="6,3"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,-5,-5,0">
                                    <TextBlock Text="{Binding LowStockItems}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Stock Alerts"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center">
                                <Run Text="{Binding LowStockItems}"/>
                                <Run Text="low stock"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <Button Style="{StaticResource QuickActionButton}"
                            Command="{Binding ViewSettingsCommand}">
                        <StackPanel>
                            <TextBlock Text="⚙️" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Settings"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock Text="Configure System"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <!-- Recent Activity Section -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Transactions -->
                    <Border Grid.Column="0" Style="{StaticResource AnimatedCard}">
                        <StackPanel>
                            <TextBlock Text="🕐 Recent Transactions"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>

                            <ItemsControl ItemsSource="{Binding RecentTransactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding TransactionNumber}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeConverter}}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Total, Converter={StaticResource CurrencyConverter}}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Top Products -->
                    <Border Grid.Column="2" Style="{StaticResource AnimatedCard}">
                        <StackPanel>
                            <TextBlock Text="🏆 Top Products"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>

                            <ItemsControl ItemsSource="{Binding TopProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Price, Converter={StaticResource CurrencyConverter}}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
