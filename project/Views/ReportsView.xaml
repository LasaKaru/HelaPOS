<UserControl x:Class="POS.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:POS.Converters"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="← Dashboard"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BackCommand}"
                            Margin="0,0,20,0"/>
                    <TextBlock Text="📊 Reports &amp; Analytics"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 Refresh"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="📥 Export CSV"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ExportToCsvCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Date Range Selector -->
        <Border Grid.Row="1"
                Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <StackPanel>
                <TextBlock Text="{Binding ReportPeriodText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Today"
                                 IsChecked="{Binding TodaySelected}"
                                 Command="{Binding SetTodayCommand}"
                                 Margin="0,0,15,0"/>
                    <RadioButton Content="This Week"
                                 IsChecked="{Binding WeekSelected}"
                                 Command="{Binding SetThisWeekCommand}"
                                 Margin="0,0,15,0"/>
                    <RadioButton Content="This Month"
                                 IsChecked="{Binding MonthSelected}"
                                 Command="{Binding SetThisMonthCommand}"
                                 Margin="0,0,15,0"/>
                    <RadioButton Content="This Year"
                                 IsChecked="{Binding YearSelected}"
                                 Command="{Binding SetThisYearCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- Overview Tab -->
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Summary Cards -->
                        <UniformGrid Rows="1" Columns="4" Margin="0,0,0,20">
                            <!-- Total Sales Card -->
                            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Background="{DynamicResource PrimaryBrush}">
                                <StackPanel>
                                    <TextBlock Text="Total Sales"
                                               FontSize="12"
                                               Foreground="White"
                                               Opacity="0.9"/>
                                    <TextBlock Text="{Binding SalesReport.TotalSales, Converter={StaticResource CurrencyConverter}}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding SalesReport.TransactionCount, StringFormat='{}{0} transactions'}"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.8"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Profit Card -->
                            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Background="{DynamicResource SuccessBrush}">
                                <StackPanel>
                                    <TextBlock Text="Total Profit"
                                               FontSize="12"
                                               Foreground="White"
                                               Opacity="0.9"/>
                                    <TextBlock Text="{Binding SalesReport.TotalProfit, Converter={StaticResource CurrencyConverter}}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding SalesReport.ProfitMargin, StringFormat='{}{0:F1}% margin'}"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.8"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Avg Transaction Card -->
                            <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Avg Transaction"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SalesReport.AverageTransaction, Converter={StaticResource CurrencyConverter}}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding SalesReport.AverageItemsPerTransaction, StringFormat='{}{0:F1} items/trans'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Items Sold Card -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Items Sold"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SalesReport.TotalItemsSold}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding SalesReport.TotalDiscounts, Converter={StaticResource CurrencyConverter}, StringFormat='{}Discounts: {0}'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Sales by Category -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Sales by Category"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,15"/>

                                <DataGrid ItemsSource="{Binding SalesReport.SalesByCategory}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          Background="Transparent"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*"/>
                                        <DataGridTextColumn Header="Sales" Binding="{Binding TotalSales, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                        <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Methods -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Payment Methods"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,15"/>

                                <DataGrid ItemsSource="{Binding SalesReport.SalesByPaymentMethod}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          Background="Transparent"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*"/>
                                        <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                        <DataGridTextColumn Header="Transactions" Binding="{Binding TransactionCount}" Width="Auto"/>
                                        <DataGridTextColumn Header="Percentage" Binding="{Binding Percentage, StringFormat='{}{0:F1}%'}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Top Products Tab -->
            <TabItem Header="Products">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource Card}" Margin="20">
                        <StackPanel>
                            <TextBlock Text="Product Performance"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>

                            <DataGrid ItemsSource="{Binding TopProducts}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="Auto"/>
                                    <DataGridTextColumn Header="Qty Sold" Binding="{Binding QuantitySold}" Width="Auto"/>
                                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Profit" Binding="{Binding Profit, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Margin" Binding="{Binding ProfitMargin, StringFormat='{}{0:F1}%'}" Width="Auto"/>
                                    <DataGridTextColumn Header="Stock" Binding="{Binding CurrentStock}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Cashier Performance Tab -->
            <TabItem Header="Cashiers">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource Card}" Margin="20">
                        <StackPanel>
                            <TextBlock Text="Cashier Performance"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>

                            <DataGrid ItemsSource="{Binding CashierStats}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cashier" Binding="{Binding UserName}" Width="*"/>
                                    <DataGridTextColumn Header="Sales" Binding="{Binding TotalSales, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Transactions" Binding="{Binding TransactionCount}" Width="Auto"/>
                                    <DataGridTextColumn Header="Avg Trans" Binding="{Binding AverageTransaction, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Items" Binding="{Binding TotalItemsSold}" Width="Auto"/>
                                    <DataGridTextColumn Header="Refunds" Binding="{Binding RefundCount}" Width="Auto"/>
                                    <DataGridTextColumn Header="Voids" Binding="{Binding VoidedTransactions}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Transactions Tab -->
            <TabItem Header="Transactions">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource Card}" Margin="20">
                        <StackPanel>
                            <TextBlock Text="Recent Transactions"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,15"/>

                            <DataGrid ItemsSource="{Binding RecentTransactions}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Transaction #" Binding="{Binding TransactionNumber}" Width="Auto"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat='{}{0:MMM dd, HH:mm}'}" Width="Auto"/>
                                    <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="Auto"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource CurrencyConverter}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3"
                Background="{DynamicResource BackgroundBrush}"
                Opacity="0.95"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳ Generating Reports..."
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Please wait..."
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
