<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Claude-Inspired Color Palette -->
    <!-- These are base colors that can be referenced in themes -->

    <!-- Primary Colors -->
    <Color x:Key="ClaudeOrange">#D97706</Color>
    <Color x:Key="ClaudeOrangeHover">#B45309</Color>
    <Color x:Key="ClaudeOrangeLight">#FEF3C7</Color>

    <!-- Neutral Colors - Light Theme -->
    <Color x:Key="LightBackground">#FFFFFF</Color>
    <Color x:Key="LightBackgroundSecondary">#F9FAFB</Color>
    <Color x:Key="LightBackgroundTertiary">#F3F4F6</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightBorder">#E5E7EB</Color>
    <Color x:Key="LightBorderHover">#D1D5DB</Color>

    <!-- Text Colors - Light Theme -->
    <Color x:Key="LightTextPrimary">#111827</Color>
    <Color x:Key="LightTextSecondary">#6B7280</Color>
    <Color x:Key="LightTextTertiary">#9CA3AF</Color>
    <Color x:Key="LightTextOnPrimary">#FFFFFF</Color>

    <!-- Neutral Colors - Dark Theme -->
    <Color x:Key="DarkBackground">#1F2937</Color>
    <Color x:Key="DarkBackgroundSecondary">#111827</Color>
    <Color x:Key="DarkBackgroundTertiary">#0F172A</Color>
    <Color x:Key="DarkSurface">#374151</Color>
    <Color x:Key="DarkBorder">#4B5563</Color>
    <Color x:Key="DarkBorderHover">#6B7280</Color>

    <!-- Text Colors - Dark Theme -->
    <Color x:Key="DarkTextPrimary">#F9FAFB</Color>
    <Color x:Key="DarkTextSecondary">#D1D5DB</Color>
    <Color x:Key="DarkTextTertiary">#9CA3AF</Color>
    <Color x:Key="DarkTextOnPrimary">#FFFFFF</Color>

    <!-- Semantic Colors -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Info">#3B82F6</Color>

</ResourceDictionary>
